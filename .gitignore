### R ###
.Rproj.user
.Rhistory
.RData
.Ruserdata

### Quarto ###
/.quarto/
**/*.quarto_ipynb

### Build artifacts — do not commit ###
index_cache/
index_files/
*_cache/
*_files/
chapters/*.html
chapters/*_files/

# Root-level render spillover — canonical output is docs/
/*.html
# …except the standalone CV pages, which are source files copied via resources:
!/cv-milan.html
!/cv-petra.html
!/cv-luka.html
/site_libs/
/*.tex
/*.aux
/*.log
/*.toc
/*.pdf

### PDF profile spurious output — only the .pdf is canonical ###
# `quarto render --profile pdf` also writes HTML into pdf/ because the
# profile inherits format settings from _quarto.yml. Ignore everything in
# pdf/ except the actual PDF.
/Javne-politike.pdf
/Prirucnik.pdf
pdf/*
!pdf/Javne-politike.pdf
!pdf/Prirucnik.pdf

# docs/pdf is the served PDF folder; renders also copy resources (apple-touch
# -icon, robots.txt, even a recursive docs/pdf/docs/…) into it. Keep only the
# two canonical PDFs.
docs/pdf/*
!docs/pdf/Javne-politike.pdf
!docs/pdf/Prirucnik.pdf

### Word (DOCX) profile output — only the .docx is canonical ###
# scripts/render-book-docx.ps1 writes word/Javne-politike.docx. The render may
# also drop pre-render / resource spillover into word/. The Word file is a LOCAL
# manuscript artifact and is never served from the website (not copied to docs/).
# Keep only the canonical .docx.
word/*
!word/Javne-politike.docx

### Temp / scratch ###
tmp/
mnt/
Razno/
/tmp_*.R
/tmp_*.py

### Leaked home-dir shell init (accidental spillover) ###
/.bashrc
/.bash_logout
/.profile

### AL (legacy) ###
.vscode/
.alcache/
.alpackages/
.snapshots/
.output/
*.app
rad.json
*.g.xlf
*.flf

# Variable-font TTFs fetched locally for the Typst booklet (regenerable).
# The book PDF (xelatex) NEEDS the static instances in fonts/print/, so those
# ARE tracked — they are a build input for the STATECRAFT PDF theme.
fonts/*
!fonts/print/

### Claude Code ###
.claude/
