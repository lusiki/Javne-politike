{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bookwright/shared/concept-ledger.schema.json",
  "title": "Concept ledger",
  "description": "Defined terms and where each is introduced and reused, so no term is defined twice or used before introduction.",
  "type": "object",
  "additionalProperties": false,
  "required": ["concepts"],
  "properties": {
    "note": { "type": "string" },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "introduced_in"],
        "properties": {
          "term": { "type": "string" },
          "canonical_definition": { "type": "string" },
          "introduced_in": { "type": "string", "description": "Chapter id where the term is first defined." },
          "reused_in": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
