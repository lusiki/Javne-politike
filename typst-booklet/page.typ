// STATECRAFT booklet — page geometry + signature cream paper.
// Header/footer (running heads + folios) are set inside typst-template.typ so
// that the title page and table of contents can opt out of them.
#set page(
  paper: "a5",
  margin: (x: 1.8cm, top: 1.9cm, bottom: 1.9cm),
  fill: rgb("#F2EDE3"),
)
